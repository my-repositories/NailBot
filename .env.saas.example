## NailBot - SaaS (Multi-tenant) example
#
# Copy to `.env` for hosted deployments:
#   cp .env.saas.example .env

# -----------------------------
# Global (shared)
# -----------------------------
MODE=saas
LOG_LEVEL=info
TZ=UTC

# SaaS production typically uses Postgres:
DATABASE_URL=postgres://nailbot:nailbot@db:5432/nailbot

# -----------------------------
# SaaS core configuration
# -----------------------------
# Optional master/control-plane bot (support, billing, internal admin UX)
SAAS_MASTER_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Where tenant bot tokens are stored/loaded from (conceptual)
# Suggested values:
# - db
# - file:/app/config/tenants.json
# - env
SAAS_TENANT_REGISTRY=db

# Example env-backed tenant tokens (only for small tenant counts)
# TENANT_1001_BOT_TOKEN=...
# TENANT_1002_BOT_TOKEN=...

# -----------------------------
# Billing (optional)
# -----------------------------
BILLING_PROVIDER=none
# BILLING_PROVIDER=stripe
# BILLING_WEBHOOK_SECRET=whsec_...
