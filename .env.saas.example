# NailBot - SaaS (multi tenant) example
#
# Copy for hosted deployment:
#   cp .env.saas.example .env
#
# Fill every value marked with "REQUIRED".

# ---------------------------------
# Runtime mode and logging
# ---------------------------------
# REQUIRED: SaaS installations must use "saas".
MODE=saas
# Suggested values: trace, debug, info, warn, error
LOG_LEVEL=info
# Use UTC in hosted environments
TZ=UTC
# REQUIRED for API container/binary
API_BIND=0.0.0.0:8080
# API endpoint used by bot container/binary
API_BASE_URL=http://api:8080

# ---------------------------------
# Database (PostgreSQL recommended for SaaS)
# ---------------------------------
# REQUIRED
DATABASE_URL=postgres://nailbot:nailbot@db:5432/nailbot
# If running bundled Postgres via docker compose:
POSTGRES_DB=nailbot
POSTGRES_USER=nailbot
POSTGRES_PASSWORD=change-this-strong-password

# ---------------------------------
# Telegram bot settings
# ---------------------------------
# Optional: control-plane bot token (support, internal admin UX)
SAAS_MASTER_BOT_TOKEN=1234567890:replace-with-master-bot-token
# REQUIRED for any tenant-facing bot worker
BOT_TOKEN=1234567890:replace-with-tenant-bot-token
# Optional but useful for backoffice commands in SaaS
ADMIN_IDS=123456789,987654321
# Optional subscription check values
CHANNEL_ID=-1001234567890
CHANNEL_LINK=https://t.me/your_channel

# ---------------------------------
# Tenant token source
# ---------------------------------
# REQUIRED: where tenant bot tokens are loaded from
# Allowed examples:
# - db
# - file:/app/config/tenants.json
# - env
SAAS_TENANT_REGISTRY=db
# For env registry mode, provide one variable per tenant:
# TENANT_1001_BOT_TOKEN=1234567890:tenant1001-token
# TENANT_1002_BOT_TOKEN=1234567890:tenant1002-token

# ---------------------------------
# Licensing (typically unused in SaaS; leave empty)
# ---------------------------------
LICENSE_KEY=
LICENSE_SERVER_URL=
INSTANCE_ID=

# ---------------------------------
# Billing integration
# ---------------------------------
# Allowed examples: none, stripe
BILLING_PROVIDER=none
# REQUIRED when BILLING_PROVIDER=stripe
BILLING_WEBHOOK_SECRET=
