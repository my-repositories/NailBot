## NailBot - On-Prem (Single-tenant) example
#
# Copy to `.env` for local dev or customer deployments:
#   cp .env.onprem.example .env

# -----------------------------
# Global (shared)
# -----------------------------
MODE=onprem
LOG_LEVEL=info
TZ=Europe/Moscow

# SQLite example (recommended for simple on-prem installs):
DATABASE_URL=sqlite:///app/data/bot.db

# PostgreSQL example (optional):
# DATABASE_URL=postgres://nailbot:nailbot@db:5432/nailbot

# -----------------------------
# On-Prem (single-tenant)
# -----------------------------
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
ADMIN_IDS=123456789,987654321

# Optional subscription check configuration
CHANNEL_ID=-1001234567890
CHANNEL_LINK=https://t.me/your_channel

# -----------------------------
# Licensing (conceptual)
# -----------------------------
LICENSE_KEY=REPLACE_ME
# LICENSE_SERVER_URL=https://licenses.example.com/verify
# INSTANCE_ID=customer-provided-stable-id
