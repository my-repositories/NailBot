# NailBot - On-Prem (single tenant) example
#
# Copy for local/dev:
#   cp .env.onprem.example .env
#
# Fill every value marked with "REQUIRED".

# ---------------------------------
# Runtime mode and logging
# ---------------------------------
# REQUIRED: on-prem installations must use "onprem".
MODE=onprem
# Suggested values: trace, debug, info, warn, error
LOG_LEVEL=info
# IANA timezone, used by scheduler/reminders
TZ=Europe/Moscow
# REQUIRED for API container/binary
API_BIND=0.0.0.0:8080
# API endpoint used by bot container/binary
API_BASE_URL=http://api:8080

# ---------------------------------
# Database
# ---------------------------------
# REQUIRED: PostgreSQL connection string (PostgreSQL-only baseline)
DATABASE_URL=postgres://boar:change_this_strong_password@db:5432/nogotochki
# If running bundled Postgres via docker compose:
POSTGRES_DB=nogotochki
POSTGRES_USER=boar
POSTGRES_PASSWORD=change_this_strong_password
# Optional PG ADMIN:
PGADMIN_EMAIL=boar@business.man
PGADMIN_PASS=very_TOP_and_HARD_passw0rD

# ---------------------------------
# Telegram bot settings
# ---------------------------------
# REQUIRED: token from @BotFather
BOT_TOKEN=1234567890:replace-with-real-bot-token
# REQUIRED: comma-separated Telegram numeric user IDs of admins
ADMIN_IDS=123456789,987654321
# Optional: public channel/supergroup ID for subscription checks
CHANNEL_ID=-1001234567890
# Optional: invite/public link shown to users
CHANNEL_LINK=https://t.me/your_channel

# ---------------------------------
# Licensing (required in on-prem mode)
# ---------------------------------
# REQUIRED: customer license key
LICENSE_KEY=replace-with-issued-license-key
# Optional: license validation endpoint (if external validation is enabled)
LICENSE_SERVER_URL=https://licenses.example.com/verify
# Optional but recommended: stable instance identifier
INSTANCE_ID=customer-prod-node-01

# ---------------------------------
# SaaS/billing keys (kept for compatibility; usually unused in on-prem)
# ---------------------------------
SAAS_MASTER_BOT_TOKEN=
SAAS_TENANT_REGISTRY=db
BILLING_PROVIDER=none
BILLING_WEBHOOK_SECRET=
